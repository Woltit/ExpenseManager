<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ExpenseManager.MAUI.TransactionDetailsPage"
             Title="Деталі транзакції">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="Повна інформація:" FontSize="20" FontAttributes="Bold" TextColor="White" />

            <Border Padding="20" BackgroundColor="#F9F9F9" Stroke="LightGray" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="15">
                    <VerticalStackLayout>
                        <Label Text="Категорія:" FontSize="12" TextColor="Gray" />
                        <Label Text="{Binding Category}" FontSize="18" FontAttributes="Bold" TextColor="Black" />
                    </VerticalStackLayout>

                    <VerticalStackLayout>
                        <Label Text="Сума:" FontSize="12" TextColor="Gray" />
                        <Label Text="{Binding Amount}" FontSize="22" FontAttributes="Bold" TextColor="DarkSlateBlue" />
                    </VerticalStackLayout>

                    <VerticalStackLayout>
                        <Label Text="Дата і час:" FontSize="12" TextColor="Gray" />
                        <Label Text="{Binding Date, StringFormat='{0:dd.MM.yyyy HH:mm}'}" FontSize="16" TextColor="Black" />
                    </VerticalStackLayout>

                    <VerticalStackLayout>
                        <Label Text="Опис (Коментар):" FontSize="12" TextColor="Gray" />
                        <Label Text="{Binding Description}" FontSize="16" TextColor="Black" FontAttributes="Italic" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>